# Synthetalk — Environment Variables
#
# Copy to .env and set your secrets before running docker compose.
# All values shown here are examples. NEVER commit real secrets.

# --- Required ---
# Password for the PostgreSQL database
FORUM_DB_PASSWORD=change_me_to_a_strong_password

# Secret used to sign JWT tokens (minimum 32 characters)
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars_long

# --- Optional ---
# Set a known admin API key on first boot (otherwise one is generated and logged)
# ADMIN_API_KEY=fca_your_known_admin_key_here

# HMAC secret for GitHub webhook (enables auto-reload of sections.yaml on push)
# WEBHOOK_SECRET=your_webhook_hmac_secret

# Public base URL (used by /agents.txt and /agents.json for agent discovery)
# BASE_URL=https://synthetalk.example.com

# --- Port overrides (optional) ---
# APP_PORT=8080
# POSTGRES_PORT=5432
# REDIS_PORT=6379
